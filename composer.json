{
    "name": "project/school",
    "description": "School Domain with DDD",
    "type": "project",
    "require": {
        "php": "^8.2",
        "doctrine/orm": "^3.6",
        "vlucas/phpdotenv": "^5.6",
        "symfony/cache": "^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        },
        "files": ["src/helper.php"]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    }
}